\uAC8C \\uD558\\uB294 \\uD50C\\uB85C\\uC6B0\\uB294 \\uC5B4\\uB824\\uC6B8 \\uC218\\uB3C4 \\uC788\\uB2E4. \\uC774 \\uC0AC\\uB78C\\uC758 \\uCDE8\\uD5A5\\uC744 \\uC54C\\uC9C0 \\uBABB\\uD558\\uBA74 \\uADF8\\uB0E5 \\uC544\\uBB34 \\uB178\\uB798\\uB098 \\uB744\\uC6CC\\uC904 \\uC218\\uBC16\\uC5D0 \\uC5C6\\uB2E4.\"), mdx(\"p\", null, \"\\uC774 \\uB178\\uB798\\uAC00 \\uB0B4 \\uCDE8\\uD5A5\\uC778\\uC9C0 \\uC544\\uB2CC\\uC9C0\\uB97C \\uBE60\\uB974\\uAC8C \\uD30C\\uC545\\uD55C\\uB2E4. => \\uCD94\\uCC9C\\uC774 \\uD544\\uC694\\uAC00 \\uC5C6\\uB2E4.\"), mdx(\"p\", null, \"\\uD0AC\\uB9C1\\uD30C\\uD2B8\\uB97C \\uB4F1\\uB85D\\uD558\\uACE0 \"), mdx(\"h2\", {\n    \"id\": \"우리는-왜-공유하는-페르소나가-최우선-페르소나가-되었나\"\n  }, \"\\uC6B0\\uB9AC\\uB294 \\uC65C \\uACF5\\uC720\\uD558\\uB294 \\uD398\\uB974\\uC18C\\uB098\\uAC00 \\uCD5C\\uC6B0\\uC120 \\uD398\\uB974\\uC18C\\uB098\\uAC00 \\uB418\\uC5C8\\uB098\"), mdx(\"p\", null, \"\\uCC98\\uC74C \\uC6B0\\uB9AC\\uAC00 \"), mdx(\"p\", null, \"\\uCD5C\\uC6B0\\uC120 \\uAC00\\uCE58\\uB294 '\\uD0AC\\uB9C1\\uD30C\\uD2B8\\uB97C '\"));\n}\n;\nMDXContent.isMDXComponent = true;","fields":{"slug":"/shook-persona/","title":"S-HOOK 페르소나","lastUpdated":"7/19/2023","lastUpdatedAt":"2023-07-19T08:08:01.000Z","gitCreatedAt":"2023-07-13T01:18:17.000Z"}}]}},"pageContext":{"slug":"/tags/기획/","tag":"기획","sidebarItems":[{"title":"","items":[{"title":"Recently Updated","url":"/latest/","collapse":true,"indent":false,"items":[{"title":"07-19: 2023년 07월","url":"/2023-07/"},{"title":"07-19: Github CODEOWNERS로 PR 리뷰어 자동 할당하기","url":"/github-codeowners/"},{"title":"07-19: S-HOOK 페르소나","url":"/shook-persona/"},{"title":"07-19: 2023년 07월 19일","url":"/2023-07-19/"},{"title":"07-19: 2차 데모데이 자료 준비","url":"/shook-second-demoday/"},{"title":"07-19: Transactional","url":"/transactional/"},{"title":"07-18: 2023년 07월 13일","url":"/2023-07-13/"},{"title":"07-18: 2023년 07월 18일","url":"/2023-07-18/"},{"title":"07-18: 2023년 07월 17일","url":"/2023-07-17/"},{"title":"07-18: Github merge 전략","url":"/github-